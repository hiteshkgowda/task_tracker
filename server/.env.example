# Port the Express server listens on
PORT=5000

# MongoDB connection string (local dev or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/task-tracker

# Comma-separated list of allowed frontend origins for CORS
# (e.g. your Vercel deployment URL). Localhost is always allowed.
CLIENT_URL=https://your-app.vercel.app

# development | production — controls morgan logging
NODE_ENV=development
